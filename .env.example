# Copy to .env — NEVER commit real keys (CLAUDE.md rule 7).

# Required only for the real Pi executor (adapter "pi"); the dryrun path needs nothing.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Executor adapter default: dryrun | flaky | alwaysfail | pi
EXECUTOR_ADAPTER=dryrun

# Telemetry (unset → tracing is a no-op)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
JAEGER_UI_URL=http://localhost:16686

# Paths (defaults are fine for local dev)
CHECKPOINT_DB=checkpoints/harness.sqlite
RUNS_ROOT=.runs
SANDBOX_IMAGE=refactor-harness-executor:latest
