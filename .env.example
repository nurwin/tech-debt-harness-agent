# Copy to .env — NEVER commit real keys (CLAUDE.md rule 7).

# Required only for the real Pi executor (adapter "pi"); the dryrun path needs nothing.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: any Anthropic-COMPATIBLE endpoint (planner + Pi executor both honor it).
# Unset → api.anthropic.com. Example — Xiaomi MiMo Token Plan: put the tp-... key in
# ANTHROPIC_API_KEY above and pick your regional endpoint
# (token-plan-cn / token-plan-sgp / token-plan-ams).
#ANTHROPIC_BASE_URL=https://token-plan-cn.xiaomimimo.com/anthropic
#LLM_MODEL=mimo-v2.5-pro

# Executor adapter default: dryrun | flaky | alwaysfail | pi
EXECUTOR_ADAPTER=dryrun

# Telemetry (unset → tracing is a no-op)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
JAEGER_UI_URL=http://localhost:16686

# Paths (defaults are fine for local dev)
CHECKPOINT_DB=checkpoints/harness.sqlite
RUNS_ROOT=.runs
SANDBOX_IMAGE=refactor-harness-executor:latest
